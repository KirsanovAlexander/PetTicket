ENV=local
LOGGER_LEVEL=info
LOGGER_FORMAT=console
LOG_REPORT_CALLER=true

LISTEN=:9000
GRPC_LISTEN=:9001

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=pet_ticket
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_MAX_OPEN_CONN=100
POSTGRES_MAX_IDLE_CONN=10
POSTGRES_CONN_MAX_LIFETIME=3600
POSTGRES_ENABLED_MIGRATION=true
POSTGRES_SSLMODE=disable

# Feature flag: false = читать комментарии из legacy tickets.comment,
# true = читать из отдельной таблицы ticket_comments (Task 11).
# Запись всегда идёт в оба места независимо от флага.
FEATURE_NEW_COMMENTS=false

# OTLP/gRPC endpoint коллектора трейсов (Jaeger). См. Task 12.
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
